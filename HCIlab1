<!DOCTYPE html>
<html>
<head>
<title>House Scene</title>
<style>
body{
    margin:0;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
    background:white;
}

.canvas{
    width:600px;
    height:400px;
    border:2px solid gray;
    position:relative;
    background:skyblue;
    overflow:hidden;
}

/* Sun */
.sun{
    width:70px;
    height:70px;
    background:yellow;
    border-radius:50%;
    position:absolute;
    top:30px;
    left:30px;
}

/* Ground */
.ground{
    width:100%;
    height:120px;
    background:green;
    position:absolute;
    bottom:0;
}

/* House Body */
.house{
    width:120px;
    height:100px;
    background:brown;
    position:absolute;
    bottom:120px;
    left:240px;
}

/* Roof */
.roof{
    width:0;
    height:0;
    border-left:70px solid transparent;
    border-right:70px solid transparent;
    border-bottom:70px solid red;
    position:absolute;
    bottom:220px;
    left:215px;
}

/* Door */
.door{
    width:30px;
    height:55px;
    background:black;
    position:absolute;
    bottom:120px;
    left:285px;
}

/* Windows */
.window1, .window2{
    width:25px;
    height:25px;
    background:white;
    position:absolute;
    bottom:170px;
}

.window1{
    left:255px;
}

.window2{
    left:325px;
}
</style>
</head>

<body>

<div class="canvas">
    <div class="sun"></div>
    <div class="ground"></div>
    <div class="roof"></div>
    <div class="house"></div>
    <div class="door"></div>
    <div class="window1"></div>
    <div class="window2"></div>
</div>

</body>
</html>
